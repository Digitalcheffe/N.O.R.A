# ── Required ──────────────────────────────────────────────────────────────────
# JWT signing secret — must be set, no default
NORA_SECRET=change-me-to-something-secure

# ── Bootstrap admin (first run only) ──────────────────────────────────────────
# Used to create the initial admin account when the users table is empty.
# Safe to remove after first login.
NORA_ADMIN_EMAIL=admin@example.com
NORA_ADMIN_PASSWORD=change-me

# ── Server ─────────────────────────────────────────────────────────────────────
NORA_PORT=8081
NORA_LOG_LEVEL=info        # set to "debug" for verbose request logging

# ── Storage ────────────────────────────────────────────────────────────────────
NORA_DB_PATH=/data/nora.db
NORA_TEMPLATES_PATH=/data/templates
NORA_ICONS_PATH=/data/icons

# ── Scheduling ─────────────────────────────────────────────────────────────────
# Cron expression for the digest email (default: 8am on the 1st of each month)
NORA_DIGEST_SCHEDULE=0 8 1 * *
# IANA timezone for digest scheduling (e.g. America/New_York, Europe/London)
NORA_TIMEZONE=UTC

# ── Web Push / VAPID ───────────────────────────────────────────────────────────
# VAPID keys are auto-generated on first run and stored in the database.
# Set these only if you need to supply your own keys (e.g. key rotation).
NORA_VAPID_PUBLIC=
NORA_VAPID_PRIVATE=
NORA_VAPID_SUBJECT=mailto:admin@localhost

# ── Email / SMTP ───────────────────────────────────────────────────────────────
# All SMTP settings are configured in-app under Settings → Notifications.
# No environment variables are needed for email.
